# .htaccess - Forum URL rewrites and security headers
# Requires mod_rewrite and AllowOverride All in Apache config.

Options -Indexes

# Security: prevent direct access to sensitive files
<FilesMatch "\.(sqlite|sqlite3|db)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

<FilesMatch "^(config|functions)\.php$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# Security headers
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# Enable rewrite engine
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /forum/

    # Redirect trailing slashes
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.*)/$ /$1 [L,R=301]
</IfModule>
